{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "my-portfolio",
	"compatibility_date": "2025-09-27",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"workers_dev": true,
	"preview_urls": true,
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "portfolio.ty-server.com",
			"custom-domain": true
		}
	]
}
